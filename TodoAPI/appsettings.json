{
  // Connection strings usadas pela aplicação.
  // Neste caso, a API utilizará a conexão chamada "DefaultConnection".
  "ConnectionStrings": {
    // Server=(localdb)\\MSSQLLocalDB -> usa a instância LocalDB instalada na máquina.
    // Database=TodoApiDb             -> nome do banco de dados.
    // Trusted_Connection=True        -> usa autenticação integrada do Windows.
    // TrustServerCertificate=True    -> aceita o certificado do servidor local.
    "DefaultConnection": "Server=RUANZITO\\SQLEXPRESS;Database=TodoAPI;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },

  // Configurações de log da aplicação.
  "Logging": {
    "LogLevel": {
      // Nível padrão de log para a aplicação.
      "Default": "Information",

      // Reduz a verbosidade dos logs internos do ASP.NET Core.
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Define quais hosts são permitidos.
  // "*" significa que a aplicação aceita requisições para qualquer host.
  "AllowedHosts": "*"
}


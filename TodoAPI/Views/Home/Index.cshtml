@model TodoAPI.ViewModels.HomeIndexViewModel
@{
    Layout = null;
    ViewData["Title"] = "Lista de Tarefas";
    var editing = Model.EditingTodo;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lista de Tarefas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <main class="container py-5">
        <h1 class="h2 mb-4">Lista de Tarefas</h1>

        @if (TempData["Message"] is string message)
        {
            <div class="alert alert-success">@message</div>
        }

        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }

        <section class="card card-body mb-4">
            <h2 class="h5 mb-3">@(editing is null ? "Nova tarefa" : "Editar tarefa")</h2>

            @* O mesmo formulario serve para criar e editar. *@
            <form asp-controller="Home"
                  asp-action="@(editing is null ? "Create" : "Edit")"
                  asp-route-id="@editing?.Id"
                  method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="Name">Nome</label>
                        <input class="form-control" id="Name" name="Name" value="@editing?.Name" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="Email">E-mail</label>
                        <input class="form-control" id="Email" name="Email" type="email" value="@editing?.Email" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="Datetime">Data</label>
                        <input class="form-control" id="Datetime" name="Datetime" type="datetime-local"
                               value="@editing?.Datetime.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="Deadline">Prazo</label>
                        <input class="form-control" id="Deadline" name="Deadline" type="datetime-local"
                               value="@editing?.Deadline.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>

                    @if (editing is not null)
                    {
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" id="IsComplete" name="IsComplete" type="checkbox"
                                       value="true" checked="@editing.IsComplete" />
                                <label class="form-check-label" for="IsComplete">Concluida</label>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-primary" type="submit">
                        @(editing is null ? "Criar tarefa" : "Salvar alteracoes")
                    </button>

                    @if (editing is not null)
                    {
                        <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Cancelar</a>
                    }
                </div>
            </form>
        </section>

        @* Mostra todas as tarefas cadastradas. *@
        <section class="table-responsive">
            <table class="table table-bordered table-hover bg-white align-middle">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Data</th>
                        <th>Prazo</th>
                        <th>Status</th>
                        <th>Acoes</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Todos.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">Nenhuma tarefa cadastrada.</td>
                        </tr>
                    }

                    @foreach (var todo in Model.Todos)
                    {
                        <tr>
                            <td>@todo.Name</td>
                            <td>@todo.Email</td>
                            <td>@todo.Datetime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@todo.Deadline.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(todo.IsComplete ? "Concluida" : "Pendente")</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-controller="Home"
                                       asp-action="Index"
                                       asp-route-editId="@todo.Id">
                                        Editar
                                    </a>

                                    <form asp-controller="Home" asp-action="Delete" asp-route-id="@todo.Id" method="post">
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Excluir</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    </main>
</body>
</html>

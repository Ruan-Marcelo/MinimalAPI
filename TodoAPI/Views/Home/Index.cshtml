@{
    ViewData["Title"] = "Lista de Tarefas";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lista de Tarefas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <main class="container py-5">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h1 class="h2 mb-0">Lista de Tarefas</h1>
            <button id="reloadButton" class="btn btn-outline-secondary" type="button">
                Atualizar
            </button>
        </div>

        <div id="message" class="alert d-none" role="alert"></div>

        <form id="todoForm" class="card card-body mb-4">
            <h2 class="h5 mb-3">Nova tarefa</h2>

            <div class="row g-3">
                <div class="col-md-6">
                    <label for="name" class="form-label">Nome</label>
                    <input id="name" name="name" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label for="email" class="form-label">E-mail</label>
                    <input id="email" name="email" type="email" class="form-control" required />
                </div>

                <div class="col-md-4">
                    <label for="datetime" class="form-label">Data</label>
                    <input id="datetime" name="datetime" type="datetime-local" class="form-control" required />
                </div>

                <div class="col-md-4">
                    <label for="deadline" class="form-label">Prazo</label>
                    <input id="deadline" name="deadline" type="datetime-local" class="form-control" required />
                </div>

                <div class="col-md-4">
                    <label for="studentId" class="form-label">Aluno</label>
                    <select id="studentId" name="studentId" class="form-select">
                        <option value="">Sem aluno</option>
                    </select>
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-primary" type="submit">Adicionar tarefa</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-bordered table-hover bg-white align-middle">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Prazo</th>
                        <th>Aluno</th>
                        <th>Concluída</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody id="todoList">
                    <tr>
                        <td colspan="6" class="text-center text-muted">Carregando...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/axios@1.13.2/dist/axios.min.js"></script>
    <script>
        const api = axios.create({
            baseURL: window.location.origin,
            headers: { "Content-Type": "application/json" }
        });

        const form = document.getElementById("todoForm");
        const list = document.getElementById("todoList");
        const message = document.getElementById("message");
        const studentSelect = document.getElementById("studentId");
        let students = [];

        function showMessage(text, type = "success") {
            message.textContent = text;
            message.className = `alert alert-${type}`;
        }

        function formatDate(value) {
            return value ? new Date(value).toLocaleString("pt-BR") : "-";
        }

        function getErrorMessage(error) {
            const errors = error.response?.data?.errors;
            if (errors) {
                return Object.values(errors).flat().join(" ");
            }

            return error.response?.data?.title || error.message || "Não foi possível concluir a operação.";
        }

        async function loadStudents() {
            const response = await api.get("/students");
            students = response.data;

            studentSelect.innerHTML = '<option value="">Sem aluno</option>';
            students.forEach(student => {
                const option = document.createElement("option");
                option.value = student.id;
                option.textContent = student.name;
                studentSelect.appendChild(option);
            });
        }

        async function loadTodos() {
            try {
                const response = await api.get("/todoitems");

                if (response.data.length === 0) {
                    list.innerHTML = '<tr><td colspan="6" class="text-center text-muted">Nenhuma tarefa cadastrada.</td></tr>';
                    return;
                }

                list.innerHTML = response.data.map(todo => {
                    const student = students.find(item => item.id === todo.studentId);

                    return `
                        <tr>
                            <td>${todo.name}</td>
                            <td>${todo.email}</td>
                            <td>${formatDate(todo.deadline)}</td>
                            <td>${student?.name ?? "-"}</td>
                            <td>
                                <input class="form-check-input" type="checkbox"
                                       ${todo.isComplete ? "checked" : ""}
                                       onchange="toggleTodo(${todo.id}, this.checked)" />
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger" type="button"
                                        onclick="deleteTodo(${todo.id})">
                                    Excluir
                                </button>
                            </td>
                        </tr>`;
                }).join("");
            } catch (error) {
                showMessage(getErrorMessage(error), "danger");
            }
        }

        async function toggleTodo(id, isComplete) {
            try {
                await api.patch(`/todoitems/${id}`, { isComplete });
                showMessage("Tarefa atualizada.");
            } catch (error) {
                showMessage(getErrorMessage(error), "danger");
                await loadTodos();
            }
        }

        async function deleteTodo(id) {
            try {
                await api.delete(`/todoitems/${id}`);
                showMessage("Tarefa excluída.");
                await loadTodos();
            } catch (error) {
                showMessage(getErrorMessage(error), "danger");
            }
        }

        form.addEventListener("submit", async event => {
            event.preventDefault();

            const studentId = studentSelect.value;
            const payload = {
                name: form.name.value,
                email: form.email.value,
                datetime: form.datetime.value,
                deadline: form.deadline.value,
                studentId: studentId ? Number(studentId) : null,
                isComplete: false
            };

            try {
                await api.post("/todoitems", payload);
                form.reset();
                showMessage("Tarefa cadastrada.");
                await loadTodos();
            } catch (error) {
                showMessage(getErrorMessage(error), "danger");
            }
        });

        document.getElementById("reloadButton").addEventListener("click", loadTodos);

        async function initialize() {
            try {
                await loadStudents();
                await loadTodos();
            } catch (error) {
                showMessage(getErrorMessage(error), "danger");
            }
        }

        initialize();
    </script>
</body>
</html>

@model TodoAPI.ViewModels.HomeIndexViewModel
@{
    Layout = null;
    ViewData["Title"] = "Lista de Tarefas";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lista de Tarefas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            min-height: 100vh;
            background:
                linear-gradient(rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.55)),
                url('/images/neymar-fundo.png') center / cover fixed;
        }

        h1 {
            color: white;
        }

        .card,
        .table {
            background-color: rgba(255, 255, 255, 0.92) !important;
        }
    </style>
</head>
<body>
    <main class="container py-5">
        <h1 class="h2 mb-4">Lista de Tarefas</h1>

        @if (TempData["Message"] is string message)
        {
            <div class="alert alert-success">@message</div>
        }

        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }

        <section class="card card-body mb-4">
            <h2 class="h5 mb-3">Nova tarefa</h2>

            <form action="/Home/Create" method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="Name">Nome</label>
                        <input class="form-control" id="Name" name="Name" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="Email">E-mail</label>
                        <input class="form-control" id="Email" name="Email" type="email" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="Datetime">Data</label>
                        <input class="form-control" id="Datetime" name="Datetime" type="datetime-local" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="Deadline">Prazo</label>
                        <input class="form-control" id="Deadline" name="Deadline" type="datetime-local" required />
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Adicionar tarefa</button>
                </div>
            </form>
        </section>

        @* Mostra todas as tarefas cadastradas. *@
        <section class="table-responsive">
            <table class="table table-bordered table-hover bg-white align-middle">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Data</th>
                        <th>Prazo</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Todos.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">Nenhuma tarefa cadastrada.</td>
                        </tr>
                    }

                    @foreach (var todo in Model.Todos)
                    {
                        <tr>
                            <td>@todo.Name</td>
                            <td>@todo.Email</td>
                            <td>@todo.Datetime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@todo.Deadline.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(todo.IsComplete ? "Concluida" : "Pendente")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    </main>
</body>
</html>
